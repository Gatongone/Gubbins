<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>netstandard2.1;net8.0;net10.0;</TargetFrameworks>
        <LangVersion>latestmajor</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <None Update="Extensions\EventSubscribeWeaklyExtensions.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>EventSubscribeWeaklyExtensions.cs</LastGenOutput>
      </None>
      <None Update="Handlers\WeakActionHandler.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>WeakActionHandler.cs</LastGenOutput>
      </None>
      <None Update="Extensions\EventSubscribeExtensions.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>EventSubscribeExtensions.cs</LastGenOutput>
      </None>
      <None Update="Extensions\EventBroadcastExtensions.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>EventBroadcastExtensions.cs</LastGenOutput>
      </None>
      <None Update="Handlers\ActionEventHandler.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>ActionEventHandler.cs</LastGenOutput>
      </None>
      <None Update="Handlers\LinkableEventHandler.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>LinkableEventHandler.cs</LastGenOutput>
      </None>
      <None Update="Extensions\LinkableEventSubscribeExtensions.tt">
        <Generator>TextTemplatingFileGenerator</Generator>
        <LastGenOutput>LinkableEventSubscribeExtensions.cs</LastGenOutput>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Handlers\WeakActionHandler.cs">
        <DependentUpon>WeakActionHandler.tt</DependentUpon>
      </Compile>
      <Compile Update="Extensions\EventSubscribeWeaklyExtensions.cs">
        <DependentUpon>EventSubscribeWeaklyExtensions.tt</DependentUpon>
      </Compile>
      <Compile Update="Extensions\EventSubscribeExtensions.cs">
        <DependentUpon>EventSubscribeExtensions.tt</DependentUpon>
      </Compile>
      <Compile Update="Extensions\EventBroadcastExtensions.cs">
        <DependentUpon>EventBroadcastExtensions.tt</DependentUpon>
      </Compile>
      <Compile Update="Handlers\ActionEventHandler.cs">
        <DependentUpon>ActionEventHandler.tt</DependentUpon>
      </Compile>
      <Compile Update="Extensions\LinkableEventSubscribeExtensions.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>LinkableEventSubscribeExtensions.tt</DependentUpon>
      </Compile>
      <Compile Update="Handlers\LinkableEventHandler.cs">
        <AutoGen>True</AutoGen>
        <DesignTime>True</DesignTime>
        <DependentUpon>LinkableEventHandler.tt</DependentUpon>
      </Compile>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\Gubbins.Enhance\Gubbins.Enhance.csproj" />
    </ItemGroup>

    <Target Name="PostBuild" BeforeTargets="PostBuildEvent">
        <PropertyGroup>
            <DotNetVer>$(TargetFramework)</DotNetVer>
            <UnitySupportVer>netstandard2.1</UnitySupportVer>
            <GodotSupportVer>net8.0</GodotSupportVer>
            <UnityOutDir>$(ProjectDir)..\..\Gubbins.Unity\Plugins</UnityOutDir>
            <GodotOutDir>$(ProjectDir)..\..\Gubbins.Godot\Plugins</GodotOutDir>
        </PropertyGroup>
        <ItemGroup>
            <OutputFiles Include="$(OutputPath)$(ProjectName).dll"/>
            <OutputFiles Include="$(OutputPath)$(ProjectName).pdb" Condition="Exists('$(OutputPath)$(ProjectName).pdb')"/>
            <OutputFiles Include="$(OutputPath)$(ProjectName).mdb" Condition="Exists('$(OutputPath)$(ProjectName).mdb')"/>
        </ItemGroup>
        <Copy SourceFiles="@(OutputFiles)" DestinationFolder="$(UnityOutDir)" SkipUnchangedFiles="true" Condition=" '$(UnityOutDir)' != '' and '$(DotNetVer)' == '$(UnitySupportVer)' "/>
        <Copy SourceFiles="@(OutputFiles)" DestinationFolder="$(GodotOutDir)" SkipUnchangedFiles="true" Condition=" '$(GodotOutDir)' != '' and '$(DotNetVer)' == '$(GodotSupportVer)' "/>
    </Target>

</Project>